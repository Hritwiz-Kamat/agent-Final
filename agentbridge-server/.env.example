# ─── Browser Engine ────────────────────────────────────────
# 'lightpanda' or 'chromium'
BROWSER_ENGINE=lightpanda

# Lightpanda CDP WebSocket endpoint
LIGHTPANDA_ENDPOINT=ws://127.0.0.1:9222

# Chromium executable path (for fallback)
# CHROMIUM_PATH=/usr/bin/chromium

# ─── Pool ──────────────────────────────────────────────────
MAX_PAGES=5
PAGE_TIMEOUT=30000
NAVIGATION_TIMEOUT=15000

# ─── Extraction ───────────────────────────────────────────
CHINESE_COMPRESSION=false
MAX_CONTENT_LENGTH=100000
USE_READABILITY=true
OBEY_ROBOTS=true

# ─── REST API ─────────────────────────────────────────────
API_PORT=3100
# API_KEY=your-secret-api-key
RATE_LIMIT_RPM=60

# ─── MCP ──────────────────────────────────────────────────
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8100

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
